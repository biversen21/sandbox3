generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Matter {
  id            String   @id @default(cuid())
  name          String
  practice_area String
  status        String   @default("intake")
  notes         String?
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  entities  Entity[]
  events    Event[]
  documents Document[]
  facts     Fact[]
  issues    Issue[]
  reports   Report[]
}

model Entity {
  id                          String   @id @default(cuid())
  matter_id                   String
  role                        String
  entity_type                 String
  name                        String
  address                     String?
  county                      String?
  state                       String?
  citizenship_state           String?
  incorporation_state         String?
  principal_place_of_business String?
  registered_agent            String?
  service_address             String?
  metadata                    String?  // JSON string; use Json type when migrating to Postgres
  created_at                  DateTime @default(now())
  updated_at                  DateTime @updatedAt

  matter Matter @relation(fields: [matter_id], references: [id], onDelete: Cascade)
  facts  Fact[]

  @@index([matter_id])
}

model Event {
  id          String    @id @default(cuid())
  matter_id   String
  event_type  String
  event_date  DateTime?
  address     String?
  county      String?
  state       String?
  description String?
  created_at  DateTime  @default(now())
  updated_at  DateTime  @updatedAt

  matter Matter @relation(fields: [matter_id], references: [id], onDelete: Cascade)
  facts  Fact[]

  @@index([matter_id])
}

model Document {
  id                String   @id @default(cuid())
  matter_id         String
  filename          String
  document_type     String?
  mime_type         String?  // e.g. application/pdf
  size_bytes        Int?     // file size in bytes
  storage_url       String?
  processing_status String    @default("pending")
  uploaded_at       DateTime  @default(now())
  extracted_text    String?
  extracted_at      DateTime?
  extraction_error  String?

  matter Matter @relation(fields: [matter_id], references: [id], onDelete: Cascade)
  facts  Fact[]

  @@index([matter_id])
}

model Fact {
  id                String   @id @default(cuid())
  matter_id         String
  entity_id         String?
  event_id          String?
  document_id       String?
  fact_type         String
  value             String
  normalized_value  String?
  confidence        Float    @default(1.0)
  extraction_method String   @default("manual")
  source_document   String?
  page_number       Int?
  human_verified    Boolean  @default(false)
  verified_by       String?
  created_at        DateTime @default(now())
  updated_at        DateTime @updatedAt

  matter   Matter    @relation(fields: [matter_id], references: [id], onDelete: Cascade)
  entity   Entity?   @relation(fields: [entity_id], references: [id])
  event    Event?    @relation(fields: [event_id], references: [id])
  document Document? @relation(fields: [document_id], references: [id])

  @@index([matter_id])
  @@index([matter_id, fact_type])
}

model Issue {
  id             String   @id @default(cuid())
  matter_id      String
  issue_type     String
  severity       String
  title          String
  description    String?
  why_it_matters String?
  status         String   @default("open")
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt

  matter Matter @relation(fields: [matter_id], references: [id], onDelete: Cascade)

  @@index([matter_id])
}

model Rule {
  id                  String   @id @default(cuid())
  rule_key            String   @unique
  practice_area       String
  jurisdiction        String   @default("general")
  required_fact_types String   // JSON array string; use Json type when migrating to Postgres
  applies_when        String?  // JSON object string; use Json type when migrating to Postgres
  severity            String
  title               String
  why_it_matters      String
  created_at          DateTime @default(now())
  updated_at          DateTime @updatedAt

  @@index([practice_area])
}

model Report {
  id              String   @id @default(cuid())
  matter_id       String
  report_type     String   @default("filing_readiness")
  readiness_score Float?
  summary         String?  // JSON string; use Json type when migrating to Postgres
  generated_at    DateTime @default(now())

  matter Matter @relation(fields: [matter_id], references: [id], onDelete: Cascade)

  @@index([matter_id])
}
