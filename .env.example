# AI Provider
# Get your key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Database
# SQLite (local dev — default)
DATABASE_URL="file:./dev.db"

# PostgreSQL (production)
# To switch to Postgres:
#   1. Change the value below to your Postgres connection string
#   2. Change `provider = "sqlite"` to `provider = "postgresql"` in prisma/schema.prisma
#   3. Run: npx prisma migrate dev --name init
# DATABASE_URL="postgresql://user:password@localhost:5432/plaintiff_readiness"
